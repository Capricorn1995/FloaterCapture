<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- External files directory for downloaded media -->
    <external-files-path
        name="media_downloads"
        path="Media/" />

    <!-- External cache for temporary files -->
    <external-cache-path
        name="media_cache"
        path="Cache/" />

    <!-- Internal files for app data -->
    <files-path
        name="internal_media"
        path="Media/" />

    <!-- Internal cache -->
    <cache-path
        name="internal_cache"
        path="Cache/" />

    <!-- Root external storage (for sharing) -->
    <root-path
        name="external_root"
        path="/" />
</paths>
