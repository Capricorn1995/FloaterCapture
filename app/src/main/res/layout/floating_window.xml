<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_capture"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:contentDescription="@string/floating_button_content_desc"
        android:src="@drawable/ic_floating_button"
        app:backgroundTint="@color/floating_button_background"
        app:fabCustomSize="56dp"
        app:maxImageSize="24dp"
        app:tint="@color/floating_button_icon"
        app:rippleColor="@color/floating_button_pressed"
        app:elevation="6dp" />

    <!-- Expandable Control Panel (initially hidden) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_control_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface_container_high">

        <!-- Include the control panel layout -->
        <include
            android:id="@+id/control_panel"
            layout="@layout/control_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </androidx.cardview.widget.CardView>

</FrameLayout>
